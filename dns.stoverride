name: DNS 优先系统·青浦电信自适应
desc: 5G/宽带自动用系统DNS，国内稳、国际快
dns: !replace
  enable: true
  listen: 0.0.0.0:53
  ipv6: false

  default-nameserver:
    - system

  # 青浦电信 DNS 顺序已调换：116.228.111.118 在前，180.168.255.18 在后
  fallback-nameserver:
    - 116.228.111.118   # 青浦电信备DNS → 现在优先
    - 180.168.255.18    # 青浦电信主DNS → 现在兜底
    - 223.5.5.5
    - 202.96.209.5

  nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  nameserver-policy:
    '+.google.com': https://1.1.1.1/dns-query
    '+.googleapis.com': https://1.1.1.1/dns-query
    '+.gstatic.com': https://1.1.1.1/dns-query
    '+.github.com': https://1.1.1.1/dns-query
    '+.githubusercontent.com': https://1.1.1.1/dns-query
    '+.lan': system
    '+.local': system
    '+.home': system
    '+': system

  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  use-hosts: true
  cache-size: 8192
  concurrent: true