name: SSID
desc: 其他

proxy-groups:
  - name: SSID
    type: select
    proxies:
      - Home
      - DIRECT
    ssid-policy:
      "SamHome5G": DIRECT  
      "SamHome": DIRECT  
      "303": Home
      cellular: Home
      default: Home

rules:
  - DOMAIN-SUFFIX,zte.home,SSID,no-resolve
  - IP-CIDR,192.168.1.0/24,SSID,no-resolve
