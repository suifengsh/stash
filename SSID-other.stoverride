name: SSID
desc: 其他

proxy-groups:
  - name: SSID
    type: select
    proxies:
      - Home
      - Home2
      - DIRECT
    ssid-policy:
      "SamHome5G": DIRECT  
      "SamHome": DIRECT  
      cellular: Home2
      default: Home2

rules:
  - DOMAIN-SUFFIX,zte.home,SSID,no-resolve
  - IP-CIDR,192.168.1.0/24,SSID,no-resolve
